# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Cloud provider keys are only needed for tasks bound to those providers. Text tasks
# default to local Ollama (no key), so these can stay blank for a fully-local setup.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ollama (local, default provider for text tasks). No API key.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_NUM_CTX=16384   # context window; MUST be large — Ollama silently truncates past it
# OLLAMA_TIMEOUT=600     # seconds; local generation (esp. first model load) is slow

# Optional: override default config locations
# YOHAKU_BINDINGS=config/bindings.json
# YOHAKU_DATA_DIR=data
